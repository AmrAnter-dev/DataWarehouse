-- silver.erp_cust_aZ12 testing
------------------------------------------------------------
--  check for null in business key
select
        *
from
        silver.erp_cust_aZ12
where
        customer_id is null;
-- check for versioning in business key
select
        customer_id,
        count(*) as version
from
        silver.erp_cust_aZ12
group by
        customer_id
having
        count(*) >1;
-- checking for duplicate in business key
with cts as
     (
             select
                     *,
                     row_number() over
                             (
                                     partition by
                                             cid
                                     order by
                                             bdate
                             )
                     as rn
             from
                     silver.erp_cust_aZ12)
select
        *
from
        cts
where
        rn >1;
select
        customer_id  ,
        birthdate,
        gender  ,
        count(*) as duplicate
from
        silver.erp_cust_aZ12
group by
        customer_id  ,
        birthdate,
        gender
having
        count(*) > 1;
--check for unwanted spaces
select
        customer_id
from
        silver.erp_cust_aZ12
where
        customer_id <> TRIM(customer_id);
-- check for boundaries in date
select
        *
from
        silver.erp_cust_aZ12
where
        try_convert(date,birthdate) >= GETDATE()
OR      try_convert(date,birthdate) < try_convert(date,'19260101');
-- checking for abnormal dates or hidden characters
select
        *
from
        silver.erp_cust_aZ12
where
        LEN(birthdate) > 10
OR      LEN(birthdate) < 10
select
        *
from
        silver.erp_cust_aZ12
where
        try_convert(date,birthdate) <> REPLACE( REPLACE( REPLACE( REPLACE (try_convert(date,birthdate), CHAR(160),''), CHAR(9),''), CHAR(10),''), CHAR(13),'')
-- checking for uniqueness in low cardinality column
select distinct
        gender
from
        silver.erp_cust_aZ12;
select
        *
from
        silver.erp_cust_aZ12
where
        TRIM(gender) = ''
OR      gender IS NULL
OR      gender = 'M';
