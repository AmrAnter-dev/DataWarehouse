-- silver.crm_sales_details testing
------------------------------------------------------------
--CHECK DEDUP OR NULL IN BUSSINESS KEY
select
        order_number,
        count(*) as duplicate_count
from
        silver.crm_sales_details
group by
        order_number
having
        count(*) > 1
and     order_number IS NULL;
select
        *
from
        silver.crm_sales_details
where
        order_number IS NULL;
--CHECK FOR UNWANTED SPACES
select
        product_key
from
        silver.crm_sales_details
where
        product_key      != TRIM(product_key)
OR      TRIM(product_key)=''
OR      product_key IS NULL;
--CHECK FOR NEGATIVE VALUE
SELECT
        customer_id
FROM
        silver.crm_sales_details
WHERE
        customer_id <= 0
OR      customer_id IS NULL;
--CHECK FOR INVALID DATES
SELECT
        *
FROM
        silver.crm_sales_details
WHERE
        TRY_CONVERT(DATE,ship_date) < TRY_CONVERT(DATE,order_date
OR      TRY_CONVERT(DATE,due_date)  < TRY_CONVERT(DATE,order_date)
OR      TRY_CONVERT(DATE,ship_date) IS NULL
OR      TRY_CONVERT(DATE,order_date) IS NULL
OR      TRY_CONVERT(DATE,due_date) IS NULL;
SELECT
        *
FROM
        silver.crm_sales_details
WHERE
        TRY_CONVERT(DATE,due_date) < TRY_CONVERT(DATE,order_date)
OR      TRY_CONVERT(DATE,due_date) < TRY_CONVERT(DATE,ship_date)
OR      TRY_CONVERT(DATE,ship_date) IS NULL
OR      TRY_CONVERT(DATE,due_date) IS NULL;
--CKECK NEGATIVE OR UNRELIABLE PRICES
SELECT
        unit_price
FROM
        silver.crm_sales_details
WHERE
        unit_price <=0
OR      unit_price IS NULL;
SELECT
        quantity
FROM
        silver.crm_sales_details
WHERE
        quantity <=0
OR      quantity IS NULL;
SELECT
        total_sales
FROM
        silver.crm_sales_details
WHERE
        total_sales <= 0
OR      total_sales IS NULL
OR      total_sales <> (quantity * unit_price);
