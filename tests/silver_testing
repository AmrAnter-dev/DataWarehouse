-- silver.crm_prd_info testing
------------------------------------------------------------
--check for duplication or versioning and null in bussiness key
-- expectation : no duplication and no null values in PK
SELECT
        *
FROM
        silver.crm_prd_info;
--versioning(Changed row over time → Version)
select
        product_key,
        count(*) as duplicate_count
from
        silver.crm_prd_info
group by
        product_key
having
        count(*) > 1;
WITH CTS AS
     (
             select
                     *,
                     row_number() over
                             (
                                     partition by
                                             product_key
                                     order by
                                             product_start_dt
                             )
                     as version_ts
             from
                     silver.crm_prd_info)
select
        *
from
        CTS
where
        product_key = 'AC-HE-HL-U509';
--null check
select
        product_id
from
        silver.crm_prd_info
where
        product_id is null;
--duplication issues(Identical rows  → Duplicate)
select
        product_key ,
        product_name  ,
        product_cost,
        product_line,
        count(*) as duplicated_num
from
        silver.crm_prd_info
group by
        product_key ,
        product_name  ,
        product_cost,
        product_line
having
        count(*) > 1;
--check for unwanted spaces for string columns
--expectation: no result
select
        product_name
from
        silver.crm_prd_info
where
        product_name      != TRIM(product_name)
or      trim(product_name)=''
or      product_name is null;
-- check the consistency of values in low cardinality columns
-- expectation: standardization and consistency
select distinct
        product_line
from
        silver.crm_prd_info;
-- check for negative or  zero prices
select
        product_cost
from
        silver.crm_prd_info
where
        product_cost <= 0;
--  check for invalid date orders
select
        *
from
        silver.crm_prd_info
where
        product_start_dt > product_end_dt;
