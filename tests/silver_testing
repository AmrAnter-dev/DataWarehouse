-- silver.crm_cust_info testing
------------------------------------------------------------
-- dedup and null removal of primary key
-- expectation : no duplication and no null values in PK

--check for duplication or versioning and null in bussiness key
--versioning(Changed row over time → Version)
select
        customer_id,
        count(*) as duplicate_count
from
        silver.crm_cust_info
group by
        customer_id
having
        count(*) > 1;
--null check
select
        *
from
        silver.crm_cust_info
where
        customer_id is null;
--duplication issues(Identical rows  → Duplicate)
select
        customer_id         ,
        customer_key        ,
        create_date,
        count(*)
from
        silver.crm_cust_info
group by
        customer_id ,
        customer_key,
        create_date
having
        count(*) > 1;
--check for unwanted spaces for string columns
--expectation: no result
select
        firstname
from
        silver.crm_cust_info
where
        firstname       != TRIM(firstname )
OR      TRIM(firstname) = ''
OR      firstname IS NULL;

-- check the consistency of values in low cardinality columns
-- expectation: standardization and consistency
select distinct
        marital_status
from
        silver.crm_cust_info;
select distinct
        gender
from
        silver.crm_cust_info;
-- checking dirty dates
SELECT DISTINCT
        create_date
FROM
        silver.crm_cust_info
ORDER BY
        create_date;
--checking column data type
select
        TABLE_SCHEMA,
        TABLE_NAME  ,
        column_name ,
        data_type   ,
        character_maximum_length
from
        information_schema.columns
where
        table_name  = 'crm_cust_info'
and     column_name = 'cst_create_date';
SELECT
        create_date                         ,
        LEN(create_date)        AS len_chars,
        DATALENGTH(create_date) AS len_bytes
FROM
        silver.crm_cust_info
where
        DATALENGTH(create_date) > (LEN(create_date) * 2);
SELECT
        TRY_CONVERT(date, REPLACE( REPLACE( REPLACE( REPLACE(LTRIM(RTRIM(create_date)), CHAR(160), ''), -- non-breaking space
        CHAR(13), ''),                                                                                      -- carriage return
        CHAR(10), ''),                                                                                      -- line feed
        CHAR(9), '')                                                                                        -- tab
        ) AS clean_date
FROM
        silver.crm_cust_info;
